# =============================================================================
# RAG-Advanced Configuration
# Copy this file to .env and update with your credentials
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration (Required)
# PostgreSQL with pgvector extension
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag_advanced
DATABASE_MIN_CONNECTIONS=2
DATABASE_MAX_CONNECTIONS=10
DATABASE_COMMAND_TIMEOUT=60

# -----------------------------------------------------------------------------
# Redis Configuration (Required for rate limiting and caching)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10

# -----------------------------------------------------------------------------
# OpenAI API (Required)
# Used for embeddings (text-embedding-3-small) and LLM (gpt-4o-mini)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key
# -----------------------------------------------------------------------------
# Anthropic API (Optional)
# Used for contextual retrieval enrichment
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# -----------------------------------------------------------------------------
# API Server Configuration
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_WORKERS=1

# -----------------------------------------------------------------------------
# Rate Limiting
# Requests per minute per API key
# -----------------------------------------------------------------------------
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# -----------------------------------------------------------------------------
# Embedding Configuration
# -----------------------------------------------------------------------------
# Backend: openai (default, 1536 dims) or bge-m3 (local, 1024 dims). Must match
# DB schema (see docker-compose or docs: schema.sql vs schema_1024.sql).
EMBEDDING_BACKEND=bge-m3
# Only used when EMBEDDING_BACKEND=openai. When bge-m3, both below are ignored (no need to change).
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
# --- For BGE-M3: set only EMBEDDING_BACKEND=bge-m3 above; no API rebuild. Ensure Postgres
#     was inited with 1024-dim schema (e.g. docker-compose -f docker-compose.yml -f docker-compose.bge-m3.yml up -d with fresh volume).

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1000

# -----------------------------------------------------------------------------
# Caching Configuration
# -----------------------------------------------------------------------------
EMBEDDING_CACHE_SIZE=10000
EMBEDDING_CACHE_TTL_SECONDS=86400
QUERY_CACHE_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_JSON=true

# -----------------------------------------------------------------------------
# Benchmark Configuration
# -----------------------------------------------------------------------------
BENCHMARK_MAX_CONCURRENT=5
BENCHMARK_DEFAULT_ITERATIONS=3

# -----------------------------------------------------------------------------
# Development Settings
# Set to false in production
# -----------------------------------------------------------------------------
DEV_MODE=true
RELOAD=true

# -----------------------------------------------------------------------------
# CORS Configuration (for frontend integration)
# Comma-separated list of allowed origins
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000

